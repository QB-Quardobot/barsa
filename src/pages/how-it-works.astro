.vs-icon{flex-shrink:0;width:16px;height:16px;display:flex;align-items:center;justify-content:center;border-radius:50%;font-size:.55rem;font-weight:700;margin-top:2px}
.vs-icon--bad{background:rgba(239,68,68,.15);color:#f87171}
.vs-icon--good{background:rgba(34,197,94,.15);color:#4ade80}
.vs-bottom{font-size:.8rem;font-weight:700;padding-top:.75rem;border-top:1px solid rgba(255,255,255,.06)}
.vs-bottom--bad{color:rgba(239,68,68,.6)}.vs-bottom--good{color:#4ade80}
@media(min-width:640px){.vs-grid-wrap{grid-template-columns:1fr 1fr;gap:1.5rem}.vs-col{padding:2rem 1.75rem;border-radius:20px}.vs-label{font-size:.8rem;margin-bottom:1.5rem}.vs-items{gap:1rem;margin-bottom:1.5rem}.vs-item{font-size:.95rem;gap:.6rem}.vs-icon{width:20px;height:20px;font-size:.65rem}.vs-bottom{font-size:.9rem;padding-top:1rem}}

.fmt-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin:2rem auto;max-width:900px}
@media(min-width:640px){.fmt-grid{grid-template-columns:repeat(3,1fr);gap:1.25rem}}
.fmt-card{padding:1.75rem 1.25rem;border-radius:20px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);text-align:center;transition:transform .3s ease,border-color .3s ease,box-shadow .3s ease}
.fmt-card:hover{transform:translateY(-4px);border-color:rgba(96,165,250,.25);box-shadow:0 8px 24px rgba(96,165,250,.1)}
.fmt-icon-wrap{width:48px;height:48px;margin:0 auto 1rem;display:flex;align-items:center;justify-content:center;border-radius:14px;background:rgba(96,165,250,.1)}
.fmt-icon{font-size:1.5rem}
.fmt-svg{width:24px;height:24px;color:rgba(96,165,250,.9)}
.fmt-card-title{font-size:1rem;font-weight:700;color:#fff;margin-bottom:.5rem}
.fmt-card-desc{font-size:.85rem;color:rgba(255,255,255,.5);line-height:1.5;margin:0}
.fmt-note{margin:2rem auto 0;max-width:700px;padding:1.5rem 1.75rem;border-radius:16px;background:linear-gradient(135deg,rgba(96,165,250,.06),rgba(139,92,246,.04));border-left:3px solid rgba(96,165,250,.4)}
.fmt-note-text{font-size:.95rem;color:rgba(255,255,255,.7);line-height:1.6;margin:0 0 .75rem}
.fmt-note-accent{font-size:.95rem;font-weight:700;color:#fff;margin:0;padding-top:.75rem;border-top:1px solid rgba(255,255,255,.06)}
</style>

<script>
  // INP FIX: Optimize video interactions
  (function() {
    'use strict';
    
    // Optimize hero video interactions for better INP
    function optimizeHeroVideo() {
      var heroVideo = document.querySelector('.hero-video[data-video-optimized="true"]');
      if (!heroVideo) return;
      
      // INP FIX: Use passive event listeners and debounce heavy operations
      var interactionTimeout = null;
      
      // Optimize click interactions - minimal handler
      var handleVideoInteraction = function(e) {
        // INP FIX: Defer any non-critical work using requestIdleCallback
        if ('requestIdleCallback' in window) {
          requestIdleCallback(function() {
            // Non-critical operations here (if needed)
          }, { timeout: 100 });
        }
        
        // Clear any pending timeouts
        if (interactionTimeout) {
          clearTimeout(interactionTimeout);
          interactionTimeout = null;
        }
      };
      
      // INP FIX: Use passive listeners where possible to avoid blocking
      // Note: click events on video controls are handled natively by browser
      // We only add lightweight listeners for optimization
      heroVideo.addEventListener('play', handleVideoInteraction, { passive: true });
      heroVideo.addEventListener('pause', handleVideoInteraction, { passive: true });
      
      // INP FIX: Optimize hover with CSS-only (no JS needed)
      // Hover effects are handled by CSS transitions
    }
    
    // Initialize video optimization when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', optimizeHeroVideo, { once: true });
    } else {
      optimizeHeroVideo();
    }
  })();
  
  // Lazy load videos in testimonials section + prevent click propagation + ensure swiper visibility
  (function() {
    function initTestimonialsVideos() {
      const lazyVideos = document.querySelectorAll('.testimonials-swiper video[data-src]');
      const swiperContainer = document.querySelector('.testimonials-swiper') as HTMLElement;
      
      // CRITICAL FIX: Ensure swiper is always visible
      function ensureSwiperVisible() {
        if (swiperContainer) {
          swiperContainer.style.display = 'block';
          swiperContainer.style.visibility = 'visible';
          swiperContainer.style.opacity = '1';
        }
        const wrapper = swiperContainer?.querySelector('.swiper-wrapper') as HTMLElement;
        if (wrapper) {
          wrapper.style.display = 'flex';
          wrapper.style.visibility = 'visible';
          wrapper.style.opacity = '1';
        }
      }
      
      // Ensure visibility immediately
      ensureSwiperVisible();
      
      if (!lazyVideos.length || typeof IntersectionObserver === 'undefined') {
        return;
      }
      
      const videoObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const video = entry.target as HTMLVideoElement;
            const dataSrc = video.getAttribute('data-src');
            
            if (dataSrc && !video.hasAttribute('data-loaded')) {
              const source = video.querySelector('source');
              if (source) {
                source.src = dataSrc;
                video.load();
                video.setAttribute('data-loaded', 'true');
                video.removeAttribute('data-src');
              }
              observer.unobserve(video);
            }
          }
        });
      }, {
        rootMargin: '100px',
        threshold: 0.1
      });
      
      lazyVideos.forEach(video => {
        videoObserver.observe(video);
        
        // CRITICAL FIX: Prevent click events on video from bubbling up to container
        video.addEventListener('click', (e) => {
          e.stopPropagation();
          e.stopImmediatePropagation();
          ensureSwiperVisible();
        }, { capture: true });
        
        // CRITICAL FIX: Ensure swiper visible on play/pause
        video.addEventListener('play', (e) => {
          e.stopPropagation();
          ensureSwiperVisible();
        }, { capture: true });
        
        video.addEventListener('pause', (e) => {
          e.stopPropagation();
          ensureSwiperVisible();
        }, { capture: true });
        
        // CRITICAL FIX: Ensure swiper visible on video events
        video.addEventListener('loadeddata', ensureSwiperVisible, { once: true });
        video.addEventListener('canplay', ensureSwiperVisible, { once: true });
      });
      
      // CRITICAL FIX: Also handle all videos in testimonials (not just lazy ones)
      const allVideos = document.querySelectorAll('.testimonials-swiper video');
      allVideos.forEach(video => {
        video.addEventListener('click', (e) => {
          e.stopPropagation();
          e.stopImmediatePropagation();
        }, { capture: true });
      });
    }
    
    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTestimonialsVideos, { once: true });
    } else {
      initTestimonialsVideos();
    }
  })();
  
  // Lazy load how-it-works module - only when page is interactive
  // This reduces initial bundle size and improves FCP
  (function() {
    function initHowItWorksLazy() {
      // Use dynamic import for code splitting
      import('../lib/how-it-works').then((module) => {
        if (module.initHowItWorks) {
          module.initHowItWorks();
        }
      }).catch((error) => {
        // Silently handle module load error
      });
    }
    
    // Wait for page to be interactive before loading
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        // OPTIMIZED: Delay page-specific code loading to improve TTI
        // Load after page is interactive and browser is idle
        if ('requestIdleCallback' in window) {
          requestIdleCallback(initHowItWorksLazy, { timeout: 2500 });
        } else {
          setTimeout(initHowItWorksLazy, 500); // Increased delay for better TTI
        }
      }, { once: true });
    } else {
      // OPTIMIZED: Delay page-specific code loading to improve TTI
      if ('requestIdleCallback' in window) {
        requestIdleCallback(initHowItWorksLazy, { timeout: 2500 });
      } else {
        setTimeout(initHowItWorksLazy, 500); // Increased delay for better TTI
      }
    }
  })();
  
  // Ultra-reliable smooth scroll to pricing - using event delegation and capture phase
  (function() {
    'use strict';
    
    var mainContentEl = document.getElementById('main-content') || document.querySelector('main');
    var isScrolling = false;
    
    // Check if element is visible in viewport
    function isElementInViewport(element, container) {
      if (!element) return false;
      var rect = element.getBoundingClientRect();
      var containerRect = container ? container.getBoundingClientRect() : {
        top: 0,
        bottom: window.innerHeight || document.documentElement.clientHeight
      };
      
      return rect.top >= containerRect.top - 150 && 
             rect.bottom <= containerRect.bottom + 150;
    }
    
    function scrollToPricing() {
      if (isScrolling) return;
      isScrolling = true;
      
      var pricingSection = document.getElementById('pricing');
      if (!pricingSection) {
        isScrolling = false;
        return;
      }
      
      // Find first tariff card (first pricing-card)
      var firstTariff = pricingSection.querySelector('.pricing-card');
      if (!firstTariff) {
        // Fallback to pricing section if no tariff found
        firstTariff = pricingSection;
      }
      
      // Pre-reveal elements
      var section = pricingSection.closest('section') || pricingSection;
      if (section) {
        var revealInstance = window.revealInstance;
        if (revealInstance && typeof revealInstance.preRevealToTarget === 'function') {
          // preRevealToTarget expects a selector string, not an element
          revealInstance.preRevealToTarget('#pricing');
        } else {
          // Manually reveal elements
          var revealElements = section.querySelectorAll('[class*="reveal-fade"]:not(.is-revealed), [class*="reveal-up"]:not(.is-revealed), [class*="reveal-scale"]:not(.is-revealed), [class*="reveal-glow"]:not(.is-revealed)');
          for (var i = 0; i < revealElements.length; i++) {
            var el = revealElements[i];
            el.style.transition = 'none';
            el.style.opacity = '1';
            el.style.transform = 'none';
            el.classList.add('is-revealed');
          }
        }
      }
      
      // Wait for layout, then scroll
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          var isMainContent = !!mainContentEl;
          var container = isMainContent ? mainContentEl : null;
          
          // PRIMARY METHOD: scrollIntoView - scroll to first tariff
          try {
            firstTariff.scrollIntoView({
              behavior: 'smooth',
              block: 'center',
              inline: 'nearest'
            });
          } catch (e) {
            var rect = firstTariff.getBoundingClientRect();
            var viewportHeight = isMainContent ? mainContentEl.clientHeight : window.innerHeight;
            var offset = viewportHeight * 0.35;
            
            if (isMainContent) {
              var scrollTop = mainContentEl.scrollTop + rect.top - offset;
              var maxScroll = mainContentEl.scrollHeight - mainContentEl.clientHeight;
              mainContentEl.scrollTo({
                top: Math.max(0, Math.min(scrollTop, maxScroll)),
                behavior: 'smooth'
              });
            } else {
              var scrollTop = (window.pageYOffset || document.documentElement.scrollTop) + rect.top - offset;
              var maxScroll = document.documentElement.scrollHeight - window.innerHeight;
              window.scrollTo({
                top: Math.max(0, Math.min(scrollTop, maxScroll)),
                behavior: 'smooth'
              });
            }
          }
          
          // Verification with retry
          var checkCount = 0;
          var maxChecks = 15;
          
          function verifyScroll() {
            checkCount++;
            var isVisible = isElementInViewport(firstTariff, container);
            
            if (isVisible) {
              isScrolling = false;
              return;
            }
            
            if (checkCount < maxChecks) {
              try {
                firstTariff.scrollIntoView({
                  behavior: 'smooth',
                  block: 'center',
                  inline: 'nearest'
                });
              } catch (e) {
                var rect = firstTariff.getBoundingClientRect();
                var viewportHeight = isMainContent ? mainContentEl.clientHeight : window.innerHeight;
                var offset = viewportHeight * 0.35;
                
                if (isMainContent) {
                  var scrollTop = mainContentEl.scrollTop + rect.top - offset;
                  mainContentEl.scrollTo({
                    top: Math.max(0, Math.min(scrollTop, mainContentEl.scrollHeight - mainContentEl.clientHeight)),
                    behavior: 'smooth'
                  });
                } else {
                  var scrollTop = (window.pageYOffset || document.documentElement.scrollTop) + rect.top - offset;
                  window.scrollTo({
                    top: Math.max(0, Math.min(scrollTop, document.documentElement.scrollHeight - window.innerHeight)),
                    behavior: 'smooth'
                  });
                }
              }
              setTimeout(verifyScroll, 200);
            } else {
              isScrolling = false;
            }
          }
          
          setTimeout(verifyScroll, 300);
          setTimeout(function() { isScrolling = false; }, 4000);
        });
      });
    }
    
    // Use event delegation with capture phase to catch events before other handlers
    function handlePricingButtonClick(e) {
      var target = e.target;
      var link = target.closest('a');
      
      if (!link) return;
      
      // Check if this is one of our target buttons
      var isButton1 = link.closest('.hero-cta') && link.classList.contains('btn-capsule') && link.getAttribute('href') === '#pricing';
      var isButton2 = (link.closest('.before-after-cta') || link.classList.contains('btn-want-same')) && link.classList.contains('btn-capsule') && link.getAttribute('href') === '#pricing';
      
      if (isButton1 || isButton2) {
        e.preventDefault();
        e.stopImmediatePropagation(); // Stop all other handlers
        scrollToPricing();
        return false;
      }
    }
    
    // Add event listener with capture phase (runs before other handlers)
    document.addEventListener('click', handlePricingButtonClick, true);
  })();
  
  // Animated Stats Counter
  (function() {
    function animateCounter(element, target, suffix = '', duration = 2000) {
      const start = 0;
      const increment = target / (duration / 16);
      let current = start;
      
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        element.textContent = Math.floor(current) + suffix;
      }, 16);
    }
    
    function initStatsAnimation() {
      const statsSection = document.querySelector('.hero-stats');
      if (!statsSection) return;
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const statValues = entry.target.querySelectorAll('.stat-value');
            statValues.forEach(stat => {
              const target = parseInt(stat.getAttribute('data-target') || '0');
              const suffix = stat.getAttribute('data-suffix') || '';
              if (target > 0) {
                animateCounter(stat, target, suffix);
              }
            });
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.3,
        rootMargin: '0px'
      });
      
      observer.observe(statsSection);
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStatsAnimation);
    } else {
      initStatsAnimation();
    }
  })();
</script>
