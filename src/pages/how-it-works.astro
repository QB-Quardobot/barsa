---
import Base from '../layouts/Base.astro';
import '../styles/how-it-works.css';
import '../styles/animations-extended.css';

---
<Base title="Как это работает - AI Model 2.0" description="Пошаговая система создания AI-модели и заработка $300–$1 000 в первый месяц.">
  
  <!-- RESOURCE HINTS: Preload critical resources for this page -->
  
  <!-- Swiper CSS - Professional CDN fallback strategy -->
  <!-- 
    Strategy:
    1. Try CDN first (jsdelivr) - fastest and most reliable
    2. If CDN fails, fallback to local copy in /public/swiper-bundle.min.css
    3. Ensures Swiper styles always load, even if CDN is blocked/unavailable
  -->
  <link 
    rel="preload" 
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" 
    as="style" 
    onload="this.onload=null;this.rel='stylesheet';"
    onerror="this.onerror=null;var link=document.createElement('link');link.rel='stylesheet';link.href='/swiper-bundle.min.css';link.crossOrigin='anonymous';document.head.appendChild(link);">
  <noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  </noscript>
  
  <!-- RESOURCE HINTS: Prefetch home page for faster navigation -->
  <!-- Prefetch index page resources when browser is idle -->
  <link rel="prefetch" href="/" as="document" slot="head">
  
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <h1 class="hero-title reveal-up">
        Запусти свою AI-модель и заработай первые <span class="gradient-text">$300–$1&nbsp;000</span> уже в первый месяц
      </h1>
      
      <div class="hero-subtitle reveal-up">
        <div class="hero-features">
          <div class="hero-feature-item">
            <div class="hero-feature-check">
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="hero-feature-text">Без лица</span>
          </div>
          <div class="hero-feature-item">
            <div class="hero-feature-check">
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="hero-feature-text">Без рекламы</span>
          </div>
          <div class="hero-feature-item">
            <div class="hero-feature-check">
              <svg width="16" height="12" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 6L5.5 10.5L15 1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="hero-feature-text">Без опыта</span>
          </div>
        </div>
        <p class="hero-subtitle-line">По моей пошаговой системе<br>с платформой, кейсами и гарантией<br>первых оплат</p>
      </div>
      
      <!-- Video Player -->
      <div class="video-container reveal-scale">
        <video 
          class="hero-video" 
          controls 
          preload="metadata"
          poster="/videos/ai-models-poster.jpg"
          playsinline
        >
          <source src="/videos/ai-models-demo.mp4" type="video/mp4">
          Ваш браузер не поддерживает видео.
        </video>
      </div>
      
      <!-- CTA Button -->
      <div class="hero-cta reveal-up">
        <a href="#pricing" class="btn-capsule" data-scroll-to="pricing" aria-label="Перейти к тарифам">
          Забронировать свое место!
        </a>
      </div>
    </div>
  </section>
  
  <!-- Two Paths Section (Ladder) -->
  <section class="two-paths-section">
    <div class="container">
      <h2 class="section-title reveal-up">
        У тебя есть два пути
      </h2>
      
      <div class="paths-ladder">
        <!-- Path 1 -->
        <div class="path-card path-card-1 reveal-slide-left">
          <div class="path-number">1</div>
          <h3 class="path-title">Сделай все сам</h3>
          <p class="path-description">
            Просто повтори пошаговую систему. Уже в первый день создашь свою первую AI-модель и поймешь, как работает механизм заработка.
          </p>
        </div>
        
        <!-- Path 2 -->
        <div class="path-card path-card-2 reveal-slide-right">
          <div class="path-number">2</div>
          <h3 class="path-title">Делегируй</h3>
          <p class="path-description">
            Найми команду, делегируй создание, общение, посты и монетизацию на них.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- How It Works Section -->
  <section class="how-it-works-section">
    <div class="container">
      <h2 class="section-title reveal-up">
        Как это работает
      </h2>
      
      <div class="stacking-cards-container">
        <!-- Step 1 -->
        <div class="work-step reveal-up" data-step="1">
          <div class="step-content">
            <div class="step-header">
              <div class="step-badge">1</div>
              <h3 class="step-title">Создаём AI-модель</h3>
            </div>
            <div class="step-image-container image-wrapper">
              <div class="shimmer-wrapper">
                <img 
                  src="/images/steps/step-1-600.webp"
                  srcset="/images/steps/step-1-600.webp 600w, /images/steps/step-1-900.webp 900w, /images/steps/step-1-1200.webp 1200w, /images/steps/step-1.webp 1920w"
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 800px"
                  alt="Создание AI-модели"
                  class="step-image"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  width="800"
                  height="450"
                />
                <div class="shimmer-overlay"></div>
              </div>
            </div>
            <ul class="step-list">
              <li>— <strong>выбираешь внешность</strong>, стиль и вайб</li>
              <li>— создаем лицо и тело, <strong>которое не отличить от реальной девушки</strong></li>
              <li>— генерируем <strong>первые фото и видео</strong></li>
            </ul>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="work-step reveal-up" data-step="2">
          <div class="step-content">
            <div class="step-header">
              <div class="step-badge">2</div>
              <h3 class="step-title">Запускаем контент</h3>
            </div>
            <div class="step-image-container image-wrapper">
              <div class="shimmer-wrapper">
                <img 
                  src="/images/steps/step-5-600.webp"
                  srcset="/images/steps/step-5-600.webp 600w, /images/steps/step-5-900.webp 900w, /images/steps/step-5-1200.webp 1200w, /images/steps/step-5.webp 1920w"
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 800px"
                  alt="Запуск контента в соцсетях"
                  class="step-image lazy-image"
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="450"
                />
                <div class="shimmer-overlay"></div>
              </div>
            </div>
            <ul class="step-list">
              <li>— подключаем Instagram, Threads, X</li>
              <li>— используем <strong>мои шаблоны постов</strong></li>
              <li>— получаем <strong>органику без рекламы</strong></li>
            </ul>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="work-step reveal-up" data-step="3">
          <div class="step-content">
            <div class="step-header">
              <div class="step-badge">3</div>
              <h3 class="step-title">Монетизация</h3>
            </div>
            <div class="step-image-container image-wrapper">
              <div class="shimmer-wrapper">
                <img 
                  src="/images/steps/step-4-600.webp"
                  srcset="/images/steps/step-4-600.webp 600w, /images/steps/step-4-900.webp 900w, /images/steps/step-4-1200.webp 1200w, /images/steps/step-4.webp 1920w"
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 800px"
                  alt="Монетизация через платформу Fanvue"
                  class="step-image lazy-image"
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="450"
                />
                <div class="shimmer-overlay"></div>
              </div>
            </div>
            <ul class="step-list">
              <li>— подключаем платформу <strong>Fanvue</strong></li>
              <li>— оформляем страницу, получаем платные подписки на <strong>AI-модель</strong></li>
              <li>— начинаем получать <strong>первые платежи</strong></li>
            </ul>
          </div>
        </div>
        
        <!-- Step 4 -->
        <div class="work-step reveal-up" data-step="4">
          <div class="step-content">
            <div class="step-header">
              <div class="step-badge">4</div>
              <h3 class="step-title">Вывод средств</h3>
            </div>
            <div class="step-image-container image-wrapper">
              <div class="shimmer-wrapper">
                <img 
                  src="/images/steps/step-3-600.webp"
                  srcset="/images/steps/step-3-600.webp 600w, /images/steps/step-3-900.webp 900w, /images/steps/step-3-1200.webp 1200w, /images/steps/step-3.webp 1920w"
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 800px"
                  alt="Вывод средств на карту или крипту"
                  class="step-image lazy-image"
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="450"
                />
                <div class="shimmer-overlay"></div>
              </div>
            </div>
            <ul class="step-list">
              <li>— выплаты на <strong>карту или крипту</strong></li>
              <li>— <strong>полностью легально</strong> и безопасно</li>
            </ul>
          </div>
        </div>
        
        <!-- Step 5 -->
        <div class="work-step reveal-up" data-step="5">
          <div class="step-content">
            <div class="step-header">
              <div class="step-badge">5</div>
              <h3 class="step-title">Масштабирование</h3>
            </div>
            <div class="step-image-container image-wrapper">
              <div class="shimmer-wrapper">
                <img 
                  src="/images/steps/step-2-600.webp"
                  srcset="/images/steps/step-2-600.webp 600w, /images/steps/step-2-900.webp 900w, /images/steps/step-2-1200.webp 1200w, /images/steps/step-2.webp 1920w"
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 800px"
                  alt="Масштабирование бизнеса с несколькими моделями"
                  class="step-image lazy-image"
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="450"
                />
                <div class="shimmer-overlay"></div>
              </div>
            </div>
            <ul class="step-list">
              <li>— создаем <strong>несколько моделей</strong></li>
              <li>— нанимаем <strong>команду для масштаба</strong></li>
              <li>— Выходим на <strong>новый уровень дохода</strong></li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- Decorative divider -->
      <div class="how-it-works-divider reveal-fade"></div>
      
      <!-- Section Summary -->
      <div class="how-it-works-summary reveal-fade">
        <p class="summary-text">Все прозрачно, просто и пошагово.</p>
        <p class="summary-text">Без воды, пустой траты времени и огромной команды.</p>
      </div>
    </div>
  </section>
  
  <!-- Alternative Content Section -->
  <section class="alternative-content-section">
    <div class="container">
      <div class="alt-content-header reveal-up">
        <div class="alt-content-photo-wrapper image-wrapper">
          <div class="shimmer-wrapper">
            <img 
              src="/images/alt-content.png"
              alt="Альтернативный контент"
              class="alt-content-photo lazy-image"
              loading="lazy"
              decoding="async"
              width="800"
              height="600"
              sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 800px"
            />
            <div class="shimmer-overlay"></div>
          </div>
        </div>
        
        <p class="alt-content-subtitle">
          Без проблем.
        </p>
        
        <p class="alt-content-description">
          Можешь создать AI-блогера, который будет <span class="gradient-text">рекламировать бренды</span>, вести сторис и делать лайфстайл-контент за тебя.
        </p>
      </div>
      
      <!-- Formats Grid - Modern Design -->
      <div class="formats-grid reveal-stagger">
        <div class="format-card reveal-bounce">
          <div class="format-icon-wrapper">
          <div class="format-icon">💪</div>
          </div>
          <h3 class="format-title">Тренер</h3>
        </div>
        <div class="format-card reveal-bounce">
          <div class="format-icon-wrapper">
          <div class="format-icon">💅</div>
          </div>
          <h3 class="format-title">Бьюти-блогер</h3>
        </div>
        <div class="format-card reveal-bounce">
          <div class="format-icon-wrapper">
          <div class="format-icon">✨</div>
          </div>
          <h3 class="format-title">Лайфстайл-инфлюенсер</h3>
        </div>
        <div class="format-card reveal-bounce">
          <div class="format-icon-wrapper">
          <div class="format-icon">🎯</div>
          </div>
          <h3 class="format-title">Эксперт в любой нише</h3>
        </div>
      </div>
      
      <div class="alt-content-note reveal-fade">
        <p class="note-text">
          Это блогер, который работает вместо тебя, <strong>24/7</strong>, без&nbsp;усталости, без&nbsp;выгорания&nbsp;и&nbsp;зарплаты.
        </p>
      </div>
    </div>
  </section>
  
  <!-- About Ilya Section -->
  <section class="about-ilya-section">
    <div class="container">
      <div class="about-ilya-content">
        <div class="ilya-photo-wrapper image-wrapper reveal-scale">
          <div class="shimmer-wrapper">
            <img 
              src="/images/ilya-photo.png"
              alt="Ilya Che"
              class="ilya-photo lazy-image"
              loading="lazy"
              decoding="async"
              width="600"
              height="800"
              sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 600px"
            />
            <div class="shimmer-overlay"></div>
          </div>
        </div>
        
        <div class="ilya-story reveal-up">
          <h2 class="ilya-title">Кто я такой</h2>
          
          
          <p class="ilya-intro">
            Меня зовут <strong>Ilya Che</strong>.
          </p>
          <p class="ilya-text reveal-fade">
            С детства я искал бизнес, где можно зарабатывать именно онлайн и при этом не сидеть в ноуте 24/7.
          </p>
          <p class="ilya-text reveal-fade">
            Пробовал все — монтаж видео, арбитраж, крипту, Shopify, и в последние годы Amazon US.
          </p>
          <p class="ilya-text reveal-fade">
            Зарабатывал <strong>2–3 тысячи евро в месяц</strong>, но постоянно выгорал.
          </p>
          <p class="ilya-text reveal-fade">
            Бесконечные документы, проверки, таблицы. Жил в постоянном стрессе, пока однажды не понял — я хочу жить и работать по-другому.
          </p>
          <p class="ilya-current reveal-up">
            Сегодня все наоборот: Я&nbsp;вышел на&nbsp;<span class="ilya-current-amount gradient-text">10.000+&nbsp;евро&nbsp;в&nbsp;месяц</span>, но работаю в&nbsp;разы меньше, <span class="ilya-current-ending">парадокс..</span>
          </p>
          <p class="ilya-text reveal-fade">
            Теперь я масштабирую свою систему и уже имею несколько AI-моделей
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Before/After Section -->
  <section class="before-after-section">
    <div class="container">
      <div class="before-after-grid reveal-scale">
        <!-- Before -->
        <div class="before-after-card before-card reveal-up">
          <div class="card-header">
            <span class="card-badge card-badge-before">🔴 Раньше</span>
          </div>
          <div class="before-photo-container image-wrapper">
            <div class="shimmer-wrapper">
              <img 
                src="/images/before.jpg"
                alt="Раньше - старая фотография"
                class="before-after-photo lazy-image"
                loading="lazy"
                decoding="async"
                width="600"
                height="800"
                sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 600px"
              />
              <div class="shimmer-overlay"></div>
            </div>
          </div>
          <div class="card-content">
            <p class="comparison-text">Я тратил <strong class="highlight-negative">больше сил</strong>, чем зарабатывал.</p>
            <p class="comparison-text">Был <strong class="highlight-negative">сильный стресс</strong>.</p>
            <p class="comparison-text"><strong class="highlight-negative">Зависел от клиентов</strong>, рекламы и курса валют.</p>
            <p class="comparison-text">Чувствовал, что <strong class="highlight-negative">работаю не на себя</strong>.</p>
            <p class="comparison-text">Постоянно боролся с <strong class="highlight-negative">конкурентами</strong>.</p>
          </div>
        </div>
        
        <!-- After -->
        <div class="before-after-card after-card reveal-up">
          <div class="card-header">
            <span class="card-badge card-badge-after">🟢 Сейчас</span>
          </div>
          <div class="after-photo-container image-wrapper">
            <div class="shimmer-wrapper">
              <img 
                src="/images/now.png"
                alt="Сейчас - новая фотография с машиной"
                class="after-photo lazy-image"
                loading="lazy"
                decoding="async"
                width="600"
                height="800"
                sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 600px"
              />
              <div class="shimmer-overlay"></div>
            </div>
          </div>
          <div class="card-content">
            <p class="comparison-text">Я создаю <strong class="highlight-positive">цифровых моделей</strong>, которые <strong class="highlight-positive">работают за меня</strong>.</p>
            <p class="comparison-text">Мой доход <strong class="highlight-positive">стабилен</strong> и <strong class="highlight-positive gradient-text">растет каждый месяц</strong>.</p>
            <p class="comparison-text">Я живу в <strong class="highlight-positive">ритме, который выбираю сам</strong>.</p>
            <p class="comparison-text highlight-zero-competition">
              В моей нише - <strong class="gradient-text highlight-glow">нулевая конкуренция</strong>
            </p>
          </div>
        </div>
      </div>
      
      <!-- CTA Button -->
      <div class="before-after-cta reveal-fade">
        <a href="#pricing" class="btn-capsule btn-want-same" data-scroll-to="pricing" aria-label="Перейти к тарифам">
          Я хочу так же
        </a>
      </div>
    </div>
  </section>
  
  <!-- Difference Section -->
  <section class="difference-section">
    <div class="container">
      <div class="difference-header reveal-up">
        <h2 class="difference-title">
          В чем отличие <span class="gradient-text">моей системы</span>
        </h2>
        <p class="difference-subtitle">
          AI-модели — это не очередной хайп и не "темка на пару месяцев".
        </p>
        <p class="difference-text">
          Это новая индустрия, которая уже бурно растет в США, а в СНГ о ней почти никто не знает.
        </p>
        <p class="difference-text">
          Я один из первых, кто перенес этот бизнес в русскоговорящее сообщество.
        </p>
        <p class="difference-highlight">
          И именно поэтому у тебя сейчас шанс войти в рынок, пока он не перегрет. 
          Это тот редкий момент, когда можно работать <strong class="gradient-text">без конкуренции</strong>.
        </p>
      </div>
      
      <!-- Google Trends Visualization Placeholder -->
      <div class="trends-visualization reveal-scale">
        <div class="trends-container">
          <div class="trend-region trend-us">
            <div class="trend-label">США</div>
            <div class="trend-bar">
              <div class="trend-fill" style="width: 85%"></div>
              <span class="trend-value">Высокий интерес</span>
            </div>
          </div>
          <div class="trend-region trend-cis">
            <div class="trend-label">СНГ</div>
            <div class="trend-bar">
              <div class="trend-fill" style="width: 8%"></div>
              <span class="trend-value">Почти неизвестно</span>
            </div>
          </div>
        </div>
        <p class="trends-note">
          Поисковые запросы по теме "AI модели" показывают разницу в популярности
        </p>
      </div>
    </div>
  </section>
  
  <!-- Comparison Section (Ladder) -->
  <section class="comparison-section">
    <div class="container">
      <div class="difference-header reveal-up">
        <h2 class="difference-title">
          Сравнение: <span class="gradient-text">Живая модель vs AI-модель</span>
        </h2>
      </div>
      
      <div class="comparison-ladder reveal-scale">
        <!-- Live Model -->
        <div class="comparison-card live-model-card reveal-up">
          <div class="comparison-header">
            <div class="comparison-photo-container image-wrapper">
              <div class="shimmer-wrapper">
                <img 
                  src="/images/real-model.png"
                  alt="Живая модель"
                  class="comparison-photo lazy-image"
                  loading="lazy"
                  decoding="async"
                  width="600"
                  height="800"
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 600px"
                />
                <div class="shimmer-overlay"></div>
              </div>
            </div>
            <h3 class="comparison-title">Живая модель</h3>
          </div>
          <ul class="comparison-list">
            <li class="comparison-item negative">
              <span class="item-icon">❌</span>
