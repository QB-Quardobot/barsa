<script>
  // Центрируем среднюю карточку при загрузке (с кэшированием DOM)
  const domReadyHandler = () => {
    try {
      // Proof cover image lazy loading
      const proofCoverImg = document.querySelector('.proof-cover-img');
      if (proofCoverImg && !proofCoverImg.classList.contains('loaded')) {
        // If image is already loaded or no data-src, just add loaded class
        if (proofCoverImg.complete && proofCoverImg.naturalHeight !== 0) {
          proofCoverImg.classList.add('loaded');
        } else {
          proofCoverImg.onload = () => {
            proofCoverImg.classList.add('loaded');
          };
        }
      }
      
      // Founder photo lazy loading
      const founderPhoto = document.querySelector('.founder-photo');
      if (founderPhoto && !founderPhoto.classList.contains('loaded')) {
        if (founderPhoto.complete && founderPhoto.naturalHeight !== 0) {
          founderPhoto.classList.add('loaded');
        } else {
          founderPhoto.onload = () => {
            founderPhoto.classList.add('loaded');
          };
        }
      }
      
      // Video preview image lazy loading
      const videoPreviewImg = document.querySelector('.video-preview-img');
      if (videoPreviewImg && !videoPreviewImg.classList.contains('loaded')) {
        if (videoPreviewImg.complete && videoPreviewImg.naturalHeight !== 0) {
          videoPreviewImg.classList.add('loaded');
        } else {
          videoPreviewImg.onload = () => {
            videoPreviewImg.classList.add('loaded');
          };
        }
      }
    } catch (e) {
      // Silently fail
    }
  };
  
  // Non-critical features - load after page is interactive using requestIdleCallback
  function initNonCriticalFeatures() {
    domReadyHandler();
    preventOrphans();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      // Use requestIdleCallback for better performance
      if ('requestIdleCallback' in window) {
        requestIdleCallback(initNonCriticalFeatures, { timeout: 3000 });
      } else {
        setTimeout(initNonCriticalFeatures, 200);
      }
    }, { once: true });
  } else {
    // Use requestIdleCallback for better performance
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initNonCriticalFeatures, { timeout: 2000 });
    } else {
      setTimeout(initNonCriticalFeatures, 200);
    }
  }
  
  // Prevent orphan words (single words on new line)
  function preventOrphans() {
    const prepositions = ['в', 'на', 'с', 'по', 'о', 'у', 'за', 'из', 'к', 'до', 'от', 'об', 'под', 'про', 'для', 'без', 'над', 'при', 'через', 'между', 'среди'];
    const shortWords = ['и', 'а', 'но', 'или', 'как', 'что', 'где', 'чем', 'оно', 'они', 'она', 'он', 'ты', 'мы', 'вы'];
    const wordsToPrevent = [...prepositions, ...shortWords];
    
    // Select all text elements
    const elements = document.querySelectorAll('p, h1, h2, h3, h4, h5, h6, span, li, .final-description, .final-action-text, .idea-item, .insight-text, .insight-subtext');
    
    elements.forEach(element => {
      // Skip if element contains HTML tags (to avoid breaking structure)
      if (element.innerHTML.includes('<strong>') || element.innerHTML.includes('<span>') || element.innerHTML.includes('<em>')) {
        return;
      }
      
      let text = element.textContent || element.innerText;
      if (!text) return;
      
      // Process each word
      wordsToPrevent.forEach(word => {
        // Match word followed by space (case insensitive)
        const regex = new RegExp(`\\b${word}\\b `, 'gi');
        text = text.replace(regex, `${word}\u00A0`); // \u00A0 is non-breaking space
      });
      
      // Only update if text changed
      if (text !== (element.textContent || element.innerText)) {
        element.textContent = text;
      }
    });
  }
  
  // Optimize lazy-loaded images to prevent white flash
  function initLazyImages() {
    try {
      const lazyImages = document.querySelectorAll('img[loading="lazy"]');
      
      if ('IntersectionObserver' in window) {
        const imageObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const img = entry.target as HTMLImageElement;
              
              // If image is already loaded, show it immediately
              if (img.complete && img.naturalHeight !== 0) {
                img.classList.add('loaded');
                observer.unobserve(img);
              } else {
                // Wait for image to load
                img.addEventListener('load', () => {
                  img.classList.add('loaded');
                }, { once: true });
                
                img.addEventListener('error', () => {
                  // Handle error - still show image to prevent white space
                  img.classList.add('loaded');
                }, { once: true });
              }
              
              observer.unobserve(img);
            }
          });
        }, {
          rootMargin: '50px' // Start loading images 50px before they enter viewport
        });
        
        lazyImages.forEach(img => imageObserver.observe(img));
      } else {
        // Fallback: show all images immediately
        lazyImages.forEach(img => {
          (img as HTMLImageElement).classList.add('loaded');
        });
      }
    } catch (e) {
      // Silently fail
    }
  }
  
  // Lazy load videos when they enter viewport + auto-play/pause on scroll (TikTok style)
  function initLazyVideos() {
    try {
      const lazyVideos = document.querySelectorAll('video[data-src]');
      const scrollContainer = document.querySelector('.solution-videos-scroll');
      
      if ('IntersectionObserver' in window && lazyVideos.length > 0) {
        // Observer for lazy loading video sources
        const videoObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const video = entry.target as HTMLVideoElement;
              const dataSrc = video.getAttribute('data-src');
              
              if (dataSrc && !video.hasAttribute('data-loaded')) {
                // Load video source
                const source = video.querySelector('source');
                if (source) {
                  source.src = dataSrc;
                  video.load();
                  video.setAttribute('data-loaded', 'true');
                  
                  // Auto-play when loaded (TikTok style)
                  video.play().catch(() => {
                    // Autoplay failed (likely due to browser policy)
                    // User will need to click play manually
                  });
                }
                
                // Remove data-src to prevent reloading
                video.removeAttribute('data-src');
                
                observer.unobserve(video);
              }
            } else {
              // Pause video when it leaves viewport
              const video = entry.target as HTMLVideoElement;
              if (video.hasAttribute('data-loaded')) {
                video.pause();
              }
            }
          });
        }, {
          root: scrollContainer,
          rootMargin: '0px',
          threshold: 0.5 // Video is considered "visible" when 50% is in view
        });
        
        lazyVideos.forEach(video => videoObserver.observe(video));
        
        // Also handle scroll events for smooth play/pause
        if (scrollContainer) {
          let scrollTimeout: number | null = null;
          const handleScroll = () => {
            if (scrollTimeout) {
              window.cancelAnimationFrame(scrollTimeout);
            }
            scrollTimeout = window.requestAnimationFrame(() => {
              const containerRect = scrollContainer.getBoundingClientRect();
              const containerCenter = containerRect.top + containerRect.height / 2;
              
              lazyVideos.forEach(video => {
                const videoRect = video.getBoundingClientRect();
                const videoCenter = videoRect.top + videoRect.height / 2;
                const distance = Math.abs(videoCenter - containerCenter);
                
                // Play video if it's centered in viewport, pause others
                if (distance < containerRect.height / 3 && video.hasAttribute('data-loaded')) {
                  video.play().catch(() => {
                    // Autoplay failed
                  });
                } else if (video.hasAttribute('data-loaded')) {
                  video.pause();
                }
              });
            });
          };
          
          scrollContainer.addEventListener('scroll', handleScroll, { passive: true });
          
          // Initial check
          handleScroll();
        }
      } else {
        // Fallback: load all videos immediately
        lazyVideos.forEach(video => {
          const dataSrc = (video as HTMLVideoElement).getAttribute('data-src');
          if (dataSrc) {
            const source = video.querySelector('source');
            if (source) {
              source.src = dataSrc;
              (video as HTMLVideoElement).load();
            }
            (video as HTMLVideoElement).setAttribute('data-loaded', 'true');
            (video as HTMLVideoElement).removeAttribute('data-src');
          }
        });
      }
    } catch (e) {
      // Silently fail
    }
  }
  
  // OPTIMIZED: Lazy load images/videos - use requestIdleCallback for better TTI
  // Delay non-critical image loading to prioritize page interactivity
  function initLazyWhenReady() {
    initLazyImages();
    initLazyVideos();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      // OPTIMIZED: Delay lazy loading to improve TTI
      if ('requestIdleCallback' in window) {
        requestIdleCallback(initLazyWhenReady, { timeout: 2000 });
      } else {
        setTimeout(initLazyWhenReady, 500); // Increased delay for better TTI
      }
    }, { once: true });
  } else {
    // OPTIMIZED: Delay lazy loading to improve TTI
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initLazyWhenReady, { timeout: 2000 });
    } else {
      setTimeout(initLazyWhenReady, 500); // Increased delay for better TTI
    }
  }
  
  // Initialize reveal animations (lazy load, non-blocking)
  // Use requestIdleCallback for better performance, fallback to setTimeout
  (function() {
    function initRevealAnimations() {
      try {
        // Check if reveal is already initialized
        if (window.revealInstance) {
          return; // Already initialized
        }
        
        // Try to access reveal instance from global
        if (typeof window.initReveal === 'function') {
          window.initReveal();
        } else {
          // Lazy load reveal module only when needed (idle time or user interaction)
          const loadReveal = () => {
            import('/src/lib/reveal-init.js').then(() => {
              if (typeof window.initReveal === 'function') {
                window.initReveal();
              }
            }).catch(() => {
              // Silently fail - reveal will be initialized when available
            });
          };
          
          // OPTIMIZED: More aggressive lazy loading for TTI - delay non-critical animations
          // Use requestIdleCallback with longer timeout to prioritize page interactivity
          if ('requestIdleCallback' in window) {
            requestIdleCallback(loadReveal, { timeout: 3000 });
          } else {
            setTimeout(loadReveal, 1000); // Increased delay for better TTI
          }
        }
      } catch (e) {
        // Silently fail - reveal will be initialized when available
      }
    }
    
    // Wait for page to be interactive before loading reveal
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        // OPTIMIZED: Delay non-critical animations to improve TTI
        // Use requestIdleCallback with longer timeout to prioritize page interactivity
        if ('requestIdleCallback' in window) {
          requestIdleCallback(initRevealAnimations, { timeout: 3000 });
        } else {
          setTimeout(initRevealAnimations, 1000); // Increased delay for better TTI
        }
      }, { once: true });
    } else {
      // OPTIMIZED: Delay non-critical animations to improve TTI
      if ('requestIdleCallback' in window) {
        requestIdleCallback(initRevealAnimations, { timeout: 3000 });
      } else {
        setTimeout(initRevealAnimations, 1000); // Increased delay for better TTI
      }
    }
  })();
</script>

