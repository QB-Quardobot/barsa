            addDebugLog('❌ Telegram WebApp NOT FOUND after 5 seconds', 'error');
            addDebugLog('⚠️ Running in browser mode (not in Telegram)', 'warn');
            updateStatus('❌ Not in Telegram', '#f00');
          }
        }, 100);
        
        // Monitor document ready state
        addDebugLog(`📄 Document state: ${document.readyState}`, 'info');
        
        let domContentLoadedFired = false;
