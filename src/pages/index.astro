  /* Student Model Pagination */
  /* Контейнер для слайдера с пагинацией */
  .student-models-swiper-wrapper {
    position: relative;
    margin-bottom: 3rem;
    padding-bottom: 0.5rem;
  }
  
  /* Instagram-стиль пагинации для моделей учеников - вынесена за рамки слайдера */
  .student-models-swiper-main {
    position: relative;
    padding-bottom: 3rem;
  }
  
  /* Static Pagination - 3 dots */
  .static-pagination {
    position: absolute !important;
    bottom: calc(-2rem + 110px) !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    display: flex !important;
    justify-content: center;
    align-items: center;
    gap: 6px !important;
    z-index: 10;
    width: auto !important;
    height: auto !important;
    min-width: auto !important;
    min-height: auto !important;
    max-width: none !important;
    max-height: none !important;
    visibility: visible !important;
    opacity: 1 !important;
    /* CRITICAL: Reset container properties that could affect children */
    font-size: 0 !important;
    line-height: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  
  .static-pagination.student-model-pagination {
    bottom: calc(-2rem + 80px) !important;
  }
  
  .static-pagination .static-pagination-dot {
    width: 7px !important;
    height: 7px !important;
    min-width: 7px !important;
    min-height: 7px !important;
    max-width: 7px !important;
    max-height: 7px !important;
    background: rgba(255, 255, 255, 0.4) !important;
    opacity: 1 !important;
    border-radius: 50% !important;
    margin: 0 !important;
    padding: 0 !important;
    display: block !important;
    flex-shrink: 0 !important;
    box-sizing: border-box !important;
    border: none !important;
    outline: none !important;
    /* CRITICAL: Static pagination - not clickable */
    pointer-events: none !important;
    cursor: default !important;
    /* CRITICAL: Reset all inherited properties that could affect size */
    font-size: 0 !important;
    line-height: 0 !important;
    vertical-align: baseline !important;
    text-indent: 0 !important;
    letter-spacing: 0 !important;
    word-spacing: 0 !important;
    /* Force exact size */
    overflow: hidden !important;
    text-overflow: clip !important;
    white-space: nowrap !important;
  }
  
  .static-pagination .static-pagination-dot:first-child {
    background: rgba(255, 255, 255, 0.95) !important;
    width: 7px !important;
    height: 7px !important;
  }
  
  /* Mobile fixes for static pagination */
  @media (max-width: 767px) {
    .static-pagination.student-model-pagination {
      position: absolute !important;
      bottom: calc(-1rem - 30px) !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      display: flex !important;
      visibility: visible !important;
      opacity: 1 !important;
      z-index: 100 !important;
    }
    
    .student-models-swiper-wrapper {
      padding-bottom: 2rem !important;
      overflow: visible !important;
      position: relative !important;
    }
    
    .student-models-swiper-main {
      overflow: visible !important;
    }
  }
  
  /* Why Important */
  .why-important {
    margin: 3rem 0;
  }
  
  .important-title {
    font-size: clamp(1.375rem, 4vw, 1.75rem);
    font-weight: 800;
