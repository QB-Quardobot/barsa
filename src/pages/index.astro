---
import Base from '../layouts/Base.astro';
import Countdown from '../components/Countdown.astro';
import EarningsTicker from '../components/EarningsTicker.astro';

const deadline = new Date();
deadline.setHours(deadline.getHours() + 24);
const deadlineISO = deadline.toISOString();

// Debug mode - set to false before production
const DEBUG_MODE = false;
---

<Base title="AI Influencer" description="Как зарабатывать $500–$2 500 на AI-моделях без команды, без лица и без вложений. Система AI Influencer.">
  
  <!-- RESOURCE HINTS: Preload critical resources for this page -->
  
  <!-- Swiper CSS - load asynchronously to prevent render blocking -->
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>
  
  <!-- Preload Hero Image for LCP optimization -->
  <!-- CRITICAL: href должен соответствовать реальному src изображения для мобильных устройств -->
  <!-- Для десктопа браузер выберет правильный размер из imagesrcset -->
  <link rel="preload" as="image" href="/images/IMG_7476.webp" fetchpriority="high" slot="head">
  
  <!-- Preload Swiper JS (loads later, but DNS/prepare connection early) -->
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" as="script" slot="head">
  
  <!-- RESOURCE HINTS: Prefetch next page for faster navigation -->
  <!-- Prefetch how-it-works page resources when browser is idle -->
  <link rel="prefetch" href="/how-it-works" as="document" slot="head">
  <link rel="prefetch" href="/how-it-works.css" as="style" slot="head">
  
  {DEBUG_MODE && (
    <div id="tg-debug-panel" style="position: fixed; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.95); color: #0f0; font-family: monospace; font-size: 11px; padding: 10px; z-index: 999999; max-height: 250px; overflow-y: auto; border-top: 2px solid #0f0; box-shadow: 0 -4px 20px rgba(0,255,0,0.3); user-select: text; -webkit-user-select: text;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 8px;">
        <strong style="color: #0ff; font-size: 13px; user-select: none;">🔧 TELEGRAM WEBAPP DEBUGGER</strong>
        <div style="display: flex; gap: 4px;">
          <button onclick="window.copyDebugLogs?.()" style="background: #808; color: #fff; border: none; padding: 4px 8px; cursor: pointer; border-radius: 3px; font-size: 10px;">📋 Copy</button>
          <button onclick="window.testFullscreen?.()" style="background: #00f; color: #fff; border: none; padding: 4px 8px; cursor: pointer; border-radius: 3px; font-size: 10px;">📱 FS</button>
          <button onclick="window.testSwipes?.()" style="background: #f80; color: #fff; border: none; padding: 4px 8px; cursor: pointer; border-radius: 3px; font-size: 10px;">🚫 Swipe</button>
          <button onclick="window.getTelegramInfo?.()" style="background: #080; color: #fff; border: none; padding: 4px 8px; cursor: pointer; border-radius: 3px; font-size: 10px;">ℹ️ Info</button>
          <button onclick="document.getElementById('tg-debug-panel').remove()" style="background: #f00; color: #fff; border: none; padding: 4px 8px; cursor: pointer; border-radius: 3px; font-size: 10px;">✕</button>
        </div>
      </div>
      <div id="tg-debug-status" style="margin-bottom: 8px; padding: 6px; background: rgba(0,100,0,0.3); border-radius: 4px; border: 1px solid #0f0; user-select: text;">
        <div style="color: #ff0;">Status: <span id="tg-status-text">Initializing...</span></div>
      </div>
      <div id="tg-debug-log" style="line-height: 1.4; max-height: 150px; overflow-y: auto; user-select: text; -webkit-user-select: text;"></div>
    </div>
  )}
  
  <!-- Hero: ЛИД-МАГНИТ -->
  <section class="hero-section">
    <div class="container" id="hero-container">
        
        <!-- Animated Dot Badge - Centered -->
        <div class="text-center mb-8 reveal-up">
          <div class="single-dot-badge">
            <span class="pulsing-dot"></span>
          </div>
        </div>
        
        <!-- Headline -->
        <h1 class="hero-title reveal-up">
          Как молодые ребята зарабатывают первые 
          <span class="gradient-text">$500–$2 500</span> на AI-моделях 
          без команды, без лица и <span class="gradient-text">без вложений</span>
        </h1>
        
        <!-- Social Proof Cover Image -->
        <div class="proof-cover reveal-scale">
          <figure class="proof-cover-image">
            <img 
              src="/images/IMG_7476.webp"
              alt="Обложка AI Influencer - заработок на AI-моделях"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="proof-cover-img"
            />
          </figure>
        </div>
        
        <!-- Divider -->
        <div class="hero-divider"></div>
        
        <!-- Pain Points Section -->
        <div class="pain-section">
          <h2 class="pain-title reveal-up">
            Хватит пытаться угадать выстрелит или нет.
          </h2>
          
          <p class="pain-text reveal-up">
            Ты уже мог попробовать крипту, NFT, товарку, арбитраж — и все заканчивалось одинаково:
          </p>
          
          <!-- Pain Points Cards -->
          <div class="pain-cards reveal-up">
            <div class="pain-card-v2">
              <span class="pain-num">01</span>
              <h3 class="pain-card-title">Просранное время</h3>
              <p class="pain-card-desc">Месяцы ушли на попытки, а результата ноль</p>
            </div>
            <div class="pain-card-v2">
              <span class="pain-num">02</span>
              <h3 class="pain-card-title">Ноль стабильности</h3>
              <p class="pain-card-desc">Сегодня работает, завтра уже нет</p>
            </div>
            <div class="pain-card-v2">
              <span class="pain-num">03</span>
              <h3 class="pain-card-title">Упущенные возможности</h3>
              <p class="pain-card-desc">Где-то рядом есть профессия будущего, а ты её ещё не попробовал</p>
            </div>
          </div>
        </div>
        
        <!-- Visual Transition Image -->
        <figure class="transition-image reveal-scale">
          <img 
            src="/missed-opportunities.webp"
            srcset="/missed-opportunities-800.webp 800w, /missed-opportunities-1200.webp 1200w, /missed-opportunities.webp 1920w"
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1200px"
            alt="Упущенные возможности - профессия будущего"
            width="1200"
            height="675"
            loading="lazy"
            decoding="async"
            class="transition-img"
          />
        </figure>
        
        <!-- Solution Section -->
        <div class="solution-section">
          <div class="solution-intro-text reveal-up">
            <h2 class="solution-big-title">НО!</h2>
            <p class="solution-description">
              В 2025 году появился рынок, где тысячи людей зарабатывают реальные деньги, 
              не снимая лица, не бегая за клиентами и не вкладывая ни цента в рекламу.
            </p>
          </div>
          
          <div class="solution-hero-card reveal-up">
            <div class="solution-badge">🔥 Новая профессия 2026</div>
            <h2 class="solution-hero-title">
              Это — <span class="gradient-text">AI-модели</span>.
            </h2>
            <p class="solution-hero-subtitle">
              Цифровые девушки, которые работают на тебя, даже пока ты спишь.
            </p>
          </div>
          
          <!-- Videos Section - TikTok Style Vertical Scroll -->
          <div class="solution-videos-container reveal-scale">
            <div class="solution-videos-scroll">
              <div class="video-wrapper" data-video="1">
                <video 
                  class="solution-video"
                  controls
                  preload="none"
                  playsinline
                  muted
                  loop
                  data-src="/videos/IMG_4652.mp4"
                >
                  <source data-src="/videos/IMG_4652.mp4" type="video/mp4">
                  Ваш браузер не поддерживает воспроизведение видео.
                </video>
              </div>
              <div class="video-wrapper" data-video="2">
                <video 
                  class="solution-video"
                  controls
                  preload="none"
                  playsinline
                  muted
                  loop
                  data-src="/videos/IMG_4651.mp4"
                >
                  <source data-src="/videos/IMG_4651.mp4" type="video/mp4">
                  Ваш браузер не поддерживает воспроизведение видео.
                </video>
              </div>
              <div class="video-wrapper" data-video="3">
                <video 
                  class="solution-video"
                  controls
                  preload="none"
                  playsinline
                  muted
                  loop
                  data-src="/videos/IMG_4650.mp4"
                >
                  <source data-src="/videos/IMG_4650.mp4" type="video/mp4">
                  Ваш браузер не поддерживает воспроизведение видео.
                </video>
              </div>
              <div class="video-wrapper" data-video="4">
                <video 
                  class="solution-video"
                  controls
                  preload="none"
                  poster="/videos/video2-poster.webp"
                  playsinline
                  muted
                  loop
                  data-src="/videos/video2-optimized.mp4"
                >
                  <source data-src="/videos/video2-optimized.mp4" type="video/mp4">
                  Ваш браузер не поддерживает воспроизведение видео.
                </video>
              </div>
            </div>
          </div>
          
          <div class="solution-promise-card reveal-up">
            <p class="promise-text">
              И если ты дочитаешь до конца, ты поймёшь, как создать свою собственную модель 
              и выйти на первые <strong class="gradient-text">$200–2500</strong>,
              используя только ноутбук и пошаговую систему, которую я называю <strong>AI Influencer</strong>.
            </p>
          </div>
        </div>
        
      </div>
    </div>
  </section>
  
  <!-- About Ilya -->
  <section class="about-section">
    <div class="container">
        
        <!-- Founder Header -->
        <div class="founder-header reveal-scale">
          <div class="founder-photo-container">
            <img 
              src="/ilya-photo.webp"
              srcset="/ilya-photo-600.webp 600w, /ilya-photo-900.webp 900w, /ilya-photo-1200.webp 1200w, /ilya-photo.webp 1280w"
              sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 600px"
              alt="Илья - AI-продюсер"
              width="600"
              height="675"
              loading="lazy"
              decoding="async"
              class="founder-photo"
            />
          </div>
        </div>
        
        <!-- Story -->
        <div class="founder-story reveal-fade">
          
          <p class="story-intro">
            Меня зовут <strong>Илья</strong>, я — AI-продюсер, который вышел на 
            <strong class="gradient-text">$30 000 в месяц</strong> благодаря AI-моделям.
          </p>
          
          <p class="story-para">
            Когда-то я был в той же точке, что и ты: прыгал из темы в тему — пробовал крипту, 
            арбитраж, шортсы, товарку, сидел ночами и искал хоть что-то, что будет работать…
          </p>
          
          <p class="story-para">
            Везде было одно и то же: или слишком рутинно, или нестабильно, 
            или все упиралось в бешеные бюджеты.
          </p>
          
          <div class="story-moment">
            <p class="moment-text">
              Я помню, как одной такой ночью листал английский YouTube и наткнулся на фразу:
            </p>
            <blockquote class="moment-quote">
              💡 "AI-модели — новая эпоха онлайн заработка"
            </blockquote>
            <p class="moment-text">
              Я не поверил. Казалось, это очередной хайп псевдо-гуру. Но решил проверить…
            </p>
            <p class="moment-result">И офигел от результатов.</p>
          </div>
          
          <p class="story-para">
            Через неделю я создал свою первую цифровую модель. 
            Когда она принесла мне первые деньги, я просто сидел и улыбался в экран…
          </p>
          
          <div class="story-stats">
            <div class="stat-line">
              <span class="stat-label">Через месяц:</span>
              <span class="stat-value gradient-text">$1,000</span>
            </div>
            <div class="stat-line featured">
              <span class="stat-label">Через 3 месяца:</span>
              <span class="stat-value gradient-text">$10,000+</span>
            </div>
          </div>
          
          <p class="story-how">
            Без команды, без офиса, без рекламы. Просто система, где все работает как часы.
          </p>
          
          <p class="story-para">
            Так как я имею огромный опыт и инструменты, то решил обучать других — 
            как за пару дней создать свою модель, которая может приносить доход каждый день.
          </p>
          
          
        </div>
        
      </div>
    </div>
  </section>
  
  <!-- What You Get -->
  <section class="what-section">
    <div class="container">
        
        <!-- Models Banner -->
        <figure class="models-banner reveal-scale">
          <img 
            src="/models-banner.webp"
            srcset="/models-banner-800.webp 800w, /models-banner-1200.webp 1200w, /models-banner.webp 1920w"
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1200px"
            alt="AI модели"
            width="1200"
            height="675"
            loading="lazy"
            decoding="async"
            class="models-banner-img"
          />
        </figure>
        
        <!-- Intro -->
        <div class="what-intro reveal-fade">
          <h2 class="what-headline">Если коротко:</h2>
          <p class="what-desc">
            Ты можешь скопировать мою систему и начать зарабатывать на AI-моделях уже в первый месяц.
          </p>
        </div>
        
        <!-- Benefits -->
        <div class="benefits-section">
          <h3 class="benefits-title">⚙️ Что ты получишь, применив систему на&nbsp;себе:</h3>
          
          <div class="benefits-list">
            <div class="benefit-item reveal-up">
              <span class="benefit-num">1</span>
              <div class="benefit-content">
                <h4 class="benefit-name">Твою собственную цифровую модель</h4>
                <p class="benefit-text">(созданную нейросетью по твоим параметрам)</p>
              </div>
            </div>
            
            <div class="benefit-item reveal-up">
              <span class="benefit-num">2</span>
              <div class="benefit-content">
                <h4 class="benefit-name">Пошаговый план</h4>
                <p class="benefit-text">как генерировать контент, который собирает просмотры и подписчиков из США (ведь эта аудитория самая платежеспособная в мире)</p>
              </div>
            </div>
            
            <div class="benefit-item reveal-up">
              <span class="benefit-num">3</span>
              <div class="benefit-content">
                <h4 class="benefit-name">Стратегию монетизации</h4>
                <p class="benefit-text">где фанаты платят за подписку и переписку с твоей моделью</p>
              </div>
            </div>
            
            <div class="benefit-item reveal-up">
              <span class="benefit-num">4</span>
              <div class="benefit-content">
                <h4 class="benefit-name">Систему вывода денег</h4>
                <p class="benefit-text">на карту или криптокошелек</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Summary -->
        <div class="what-summary reveal-fade">
          <p class="summary-main">
            Ты создаешь персонажа — а система делает все остальное: трафик, монетизацию, выплаты.
          </p>
          
          <div class="no-hassle">
            <div class="no-item">
              <span class="no-icon">❌</span>
              <span class="no-text">Никаких пустых вливаний в рекламу</span>
            </div>
            <div class="no-item">
              <span class="no-icon">❌</span>
              <span class="no-text">Никаких рискованных схем</span>
            </div>
            <div class="no-item">
              <span class="no-icon">❌</span>
              <span class="no-text">Никаких огромных команд</span>
            </div>
            <div class="no-item">
              <span class="no-icon">❌</span>
              <span class="no-text">Никакой конкуренции</span>
            </div>
          </div>
        </div>
        
        <!-- Final CTA -->
        <div class="final-pitch reveal-fade">
          <p class="pitch-profession">
            Просто новая профессия 2026 года — <span class="gradient-text">AI-продюсер</span>.
          </p>
          <p class="pitch-formula">
            Только Ты + Ноут + Немного времени <span class="no-break">= 💸</span>
          </p>
        </div>
        
      </div>
    </div>
  </section>
  
  <!-- System -->
  <section class="system-section">
    <div class="container">
        
        <!-- System Showcase Image -->
        <figure class="system-showcase reveal-scale">
          <img 
            src="/system-showcase.webp"
            srcset="/system-showcase-800.webp 800w, /system-showcase-1200.webp 1200w, /system-showcase.webp 1920w"
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1200px"
            alt="Вот так выглядит система с AI-Моделями"
            width="1200"
            height="675"
            loading="lazy"
            decoding="async"
            class="system-showcase-img"
          />
        </figure>
        
        <!-- Header -->
        <div class="system-header reveal-fade">
          <h2 class="system-main-title">📦 Вот так выглядит система с AI-Моделями:</h2>
        </div>
        
        <!-- Timeline -->
        <div class="system-timeline">
          
          <div class="timeline-step reveal-up">
            <div class="step-marker">
              <span class="step-num">1</span>
            </div>
            <div class="step-card">
              <h3 class="step-title">Создание AI-модели с нуля</h3>
              <ul class="step-list">
                <li>– Подбор внешности, стиля и вайба</li>
                <li>– Создание самой ai-модели (которую никто не отличит от реальной девушки)</li>
                <li>– Генерация визуала для Instagram/ Threads и других соцсетей для продвижения</li>
              </ul>
            </div>
          </div>
          
          <div class="timeline-step reveal-up">
            <div class="step-marker">
              <span class="step-num">2</span>
            </div>
            <div class="step-card">
              <h3 class="step-title">Контент-система</h3>
              <ul class="step-list">
                <li>– Готовые шаблоны постов</li>
                <li>– Стратегия продвижения на американскую аудиторию</li>
                <li>– Органический трафик без вложений</li>
              </ul>
            </div>
          </div>
          
          <div class="timeline-step reveal-up">
            <div class="step-marker">
              <span class="step-num">3</span>
            </div>
            <div class="step-card">
              <h3 class="step-title">Монетизация и платформа Fanvue</h3>
              <ul class="step-list">
                <li>– Как оформить аккаунт</li>
                <li>– Как вести переписку и выстраивать психологию общения</li>
                <li>– Как зарабатывать с первых дней</li>
                <li>– как полностью делегировать переписку</li>
              </ul>
            </div>
          </div>
          
          <div class="timeline-step reveal-up">
            <div class="step-marker">
              <span class="step-num">4</span>
            </div>
            <div class="step-card">
              <h3 class="step-title">Автоматизация и масштаб</h3>
              <ul class="step-list">
                <li>– Делегирование задач</li>
                <li>– Запуск второй модели</li>
                <li>– Выход на стабильные <strong class="text-green">$10 000–$30 000/мес</strong></li>
              </ul>
            </div>
          </div>
          
          <div class="timeline-step reveal-up">
            <div class="step-marker">
              <span class="step-num">5</span>
            </div>
            <div class="step-card">
              <h3 class="step-title">Американская система MHP (Mind Hunter Protocol)</h3>
              <ul class="step-list">
                <li>– Психология американского рынка</li>
                <li>– Гарантированное получение клиентов</li>
                <li>– Быстрый доход в течение первого месяца</li>
              </ul>
            </div>
          </div>
          
        </div>
        
        <!-- CTA -->
        <div class="system-finale reveal-fade">
          <p class="finale-text">🔥 И все это есть в моей программе <strong class="gradient-text">«AI Influencer»</strong></p>
        </div>
        
      </div>
    </div>
  </section>
  
  <!-- Why Now -->
  <section class="why-now-section">
    <div class="container">
        
        <!-- Intro -->
        <div class="why-intro reveal-fade">
          <h2 class="why-main-title">Смотри.</h2>
          <p class="why-para">
            Ты уже видел, как новые темки появляются и исчезают.<br/>
            Крипта, NFT, арбитраж — взлет, хайп, обвал.
          </p>
          <p class="why-standout">
            AI-модели — это совсем другое.
          </p>
        </div>
        
        <!-- Industry Block -->
        <div class="why-industry reveal-up">
          <p class="industry-text">
            Это целая <strong>индустрия</strong>, где все только&nbsp;начинается.
          </p>
          <div class="industry-points">
            <div class="point-line">📈 Спрос огромный, конкуренции почти нет</div>
            <div class="point-line">🎯 Ты не зависишь от бирж, курсов или&nbsp;удачи</div>
          </div>
