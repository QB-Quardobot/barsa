  /* Why CTA Block - Optimized (no backdrop-filter) */
  .why-cta-block {
    margin: 3rem 0;
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, 
      rgba(249, 115, 22, 0.22) 0%, /* Increased opacity instead of blur */
      rgba(234, 88, 12, 0.18) 50%,
