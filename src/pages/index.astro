  /* === FINAL CTA SECTION === - Optimized for fast rendering */
  .final-cta-section {
    padding: 3rem 0 1.5rem 0;
    /* Ensure this section is always rendered (no lazy rendering) */
    content-visibility: visible;
    /* GPU acceleration */
    transform: translateZ(0);
    will-change: contents;
    /* Prevent clipping of child elements like click-sticker */
    overflow-x: hidden;
    overflow-y: visible;
