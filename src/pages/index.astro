  /* === STATS SECTION === - Optimized (no backdrop-filter) */
  .stats-section {
    background: rgba(13, 13, 16, 0.7); /* Increased opacity instead of blur */
    padding: 3rem 1rem;
  }
  
  @media (min-width: 768px) {
    .stats-section {
      padding: 5rem 2rem;
