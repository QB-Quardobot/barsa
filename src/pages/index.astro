  /* Why Value - Optimized (no backdrop-filter) */
  .why-value {
    margin: 3rem 0 0 0;
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, 
      rgba(96, 165, 250, 0.18) 0%, /* Increased opacity instead of blur */
      rgba(34, 211, 238, 0.12) 50%,
      rgba(96, 165, 250, 0.18) 100%
    );
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(96, 165, 250, 0.2);
    box-shadow: 
      0 4px 16px rgba(96, 165, 250, 0.15), /* Reduced blur */
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 0 0 1px rgba(96, 165, 250, 0.05);
    position: relative;
    overflow: hidden;
    /* GPU acceleration - only animate transform and opacity */
    transform: translateZ(0);
    will-change: transform;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
  }
  
  .why-value::before {
    content: '';
    position: absolute;
    top: 0;
    left: -50%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(96, 165, 250, 0.1) 50%,
      transparent 100%
    );
    animation: shimmer 3s ease-in-out infinite;
    pointer-events: none;
  }
  
  @keyframes shimmer {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0; }
    50% { transform: translateX(0%) translateY(0); opacity: 1; }
  }
  
  .why-value:hover {
    border-color: rgba(96, 165, 250, 0.35);
    box-shadow: 
      0 6px 24px rgba(96, 165, 250, 0.2), /* Reduced blur */
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 0 0 1px rgba(96, 165, 250, 0.1);
    transform: translateY(-2px) translateZ(0); /* GPU acceleration */
  }
  
  .value-text {
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    color: #e5e5e5;
    line-height: 1.8;
    font-weight: 500;
    position: relative;
    z-index: 1;
